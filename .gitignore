# Info 目录（运行时数据，不跟踪）
info/movies/*
info/backup/*
info/covers/*
info/logs/*
!info/movies/.gitkeep
!info/backup/.gitkeep
!info/covers/.gitkeep
!info/logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data (不跟踪数据库和封面图)
data/*.db
data/*.db-journal
data/covers/*
!data/covers/.gitkeep

data/avatars/*
!data/avatars/.gitkeep

data\avatars

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Environment
.env.local
.env.*.local

# Build
*.egg-info/
dist/
build/

# Tests（测试文件统一放 tests/，不纳入版本追踪）
tests/
